// Municipal e-services — extensible for departments & multi-employee assignment

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

/// Admin / employee / citizen
model User {
  id             String   @id @default(cuid())
  /// للموظفين/الإدارة غالباً؛ للمواطن — البريد للتفعيل والإشعارات
  email          String?  @unique
  /// رقم واتساب (أرقام فقط بعد التطبيع) — تسجيل دخول المواطن
  phone          String?  @unique
  /// الرقم الوطني (المواطن) — فريد عند التسجيل
  nationalId     String?  @unique
  /// بريد اختياري لإشعارات لاحقة (بريد/واتساب داخل النظام حالياً داخلياً)
  notificationEmail String? @unique
  passwordHash   String
  name           String
  role           UserRole @default(CITIZEN)
  /// للمواطن: لا يُسمح بالدخول قبل التحقق من البريد (OTP)
  isVerified     Boolean  @default(true)
  isActive       Boolean  @default(true)
  /// لوحة الإدارة — للموظف؛ المدير يُعامل كامتلاك الجميع في التطبيق
  permManageServices Boolean @default(false)
  permManageUsers    Boolean @default(false)
  permViewStats      Boolean @default(false)
  /// Future: assign services & routing by department
  departmentId   String?
  department     Department? @relation("DepartmentEmployees", fields: [departmentId], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  citizenRequests    Request[]          @relation("CitizenRequests")
  assignedRequests   Request[]          @relation("Assignee")
  statusLogs         RequestStatusLog[] @relation("LogActor")
  requestNotes       RequestNote[]      @relation("NoteAuthor")
  notifications      Notification[]
  citizenFeedbacks        CitizenFeedback[]
  citizenFeedbackReplies CitizenFeedback[] @relation("CitizenFeedbackRepliedBy")
  gasRequests        GasRequest[]
  assignedGasRequests GasRequest[] @relation("GasRequestAgent")
  returneeRegistrations ReturneeRegistration[]
  socialServiceCases SocialServiceCase[]

  /// للمعتمد (GAS_AGENT): المنطقة المكلّف بها (فريدة لكل معتمد)
  gasArea            String?  @unique
}

/// شكاوى ومقترحات المواطنين بخصوص التطبيق والخدمات
model CitizenFeedback {
  id        String   @id @default(cuid())
  citizenId String
  citizen   User     @relation(fields: [citizenId], references: [id], onDelete: Cascade)
  message   String
  createdAt DateTime @default(now())

  /// رد الإدارة على نفس الشكوى/المقترح
  adminReply       String?
  adminReplyAt     DateTime?
  adminRepliedById String?
  adminRepliedBy   User?    @relation("CitizenFeedbackRepliedBy", fields: [adminRepliedById], references: [id], onDelete: SetNull)
  notifications    Notification[]

  @@index([citizenId])
  @@index([createdAt])
  @@index([adminRepliedById])
}

/// بيانات تسجيل مواطن قبل إتمام التحقق من البريد — لا يُنشأ User حتى يُدخل الرمز صحيحاً
model PendingCitizenRegistration {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  phone        String
  nationalId   String
  /// نافذة لإكمال إدخال الرمز (أطول من صلاحية رمز OTP الواحد)
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  @@index([expiresAt])
  @@index([phone])
  @@index([nationalId])
}

/// رموز OTP للبريد (تفعيل الحساب أو استعادة كلمة المرور)
model EmailOtp {
  id        String    @id @default(cuid())
  email     String
  /// SHA-256 HMAC للرمز المكوّن من 6 أرقام (لا يُخزَّن النص الصريح)
  codeHash  String
  purpose   OtpPurpose
  expiresAt DateTime
  used      Boolean   @default(false)
  createdAt DateTime  @default(now())

  @@index([email, purpose])
}

enum OtpPurpose {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

enum UserRole {
  ADMIN
  EMPLOYEE
  CITIZEN
  GAS_AGENT
}

/// Future: departments, employee pools, per-service routing
model Department {
  id          String   @id @default(cuid())
  name        String
  code        String?  @unique
  description String?  @default("")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  services  Service[] @relation("ServiceDepartment")
  employees User[]    @relation("DepartmentEmployees")
  requests  Request[] @relation("RequestDepartment")
}

model Service {
  id             String   @id @default(cuid())
  name           String
  description    String   @default("")
  /// Stored as decimal string in SQLite; use Prisma Decimal in app
  price          String   @default("0")
  isActive       Boolean  @default(true)
  /// Future: used for automatic routing
  departmentId   String?
  department     Department? @relation("ServiceDepartment", fields: [departmentId], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  documents  ServiceDocument[]
  requests   Request[]
}

/// Required papers for a service — dynamic form = list of file inputs (+ metadata)
model ServiceDocument {
  id          String   @id @default(cuid())
  serviceId   String
  service     Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  name        String
  isRequired  Boolean  @default(true)
  fileType    FileKind @default(PDF)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  requestFiles RequestFile[] @relation("FileForDocument")
}

enum FileKind {
  IMAGE
  PDF
  ANY
}

model Request {
  id            String   @id @default(cuid())
  requestNumber String   @unique
  serviceId     String
  service       Service  @relation(fields: [serviceId], references: [id])
  citizenId     String
  citizen       User     @relation("CitizenRequests", fields: [citizenId], references: [id])
  /// Current phase: all requests go to the single (or first) assignee; nullable until assigned
  assigneeId    String?
  assignee      User?    @relation("Assignee", fields: [assigneeId], references: [id])
  departmentId  String?
  department    Department? @relation("RequestDepartment", fields: [departmentId], references: [id])
  status        RequestStatus @default(PENDING)
  /// بيانات مُدخلة مع الطلب (نسخة عند التقديم)
  submittedFullName            String?
  submittedPhone               String?
  submittedNotificationEmail   String?
  /// Optional JSON for future extra form fields
  formPayload   String?  @default("{}")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  files         RequestFile[]
  statusLogs    RequestStatusLog[]
  notes         RequestNote[]
  notifications Notification[] @relation("RequestNotifications")
}

enum RequestStatus {
  PENDING
  UNDER_REVIEW
  NEEDS_MODIFICATION
  APPROVED
  REJECTED
  COMPLETED
}

model RequestFile {
  id                 String  @id @default(cuid())
  requestId          String
  request            Request @relation(fields: [requestId], references: [id], onDelete: Cascade)
  serviceDocumentId  String
  serviceDocument    ServiceDocument @relation("FileForDocument", fields: [serviceDocumentId], references: [id])
  storedName         String
  originalName       String
  mimeType           String
  size               Int
  createdAt          DateTime @default(now())
}

/// Audit trail for every status change
model RequestStatusLog {
  id             String   @id @default(cuid())
  requestId      String
  request        Request  @relation(fields: [requestId], references: [id], onDelete: Cascade)
  actorId        String
  actor          User     @relation("LogActor", fields: [actorId], references: [id])
  fromStatus     RequestStatus?
  toStatus       RequestStatus
  noteForCitizen String?  @default("")
  createdAt      DateTime @default(now())
}

/// Internal staff notes
model RequestNote {
  id          String   @id @default(cuid())
  requestId   String
  request     Request  @relation(fields: [requestId], references: [id], onDelete: Cascade)
  authorId    String
  author      User     @relation("NoteAuthor", fields: [authorId], references: [id])
  body        String
  createdAt   DateTime @default(now())
}

model Notification {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type       String
  title      String
  message    String
  read       Boolean  @default(false)
  requestId  String?
  request    Request? @relation("RequestNotifications", fields: [requestId], references: [id], onDelete: SetNull)
  gasRequestId String?
  gasRequest   GasRequest? @relation(fields: [gasRequestId], references: [id], onDelete: SetNull)
  returneeRegistrationId String?
  returneeRegistration ReturneeRegistration? @relation(fields: [returneeRegistrationId], references: [id], onDelete: SetNull)
  socialServiceCaseId String?
  socialServiceCase   SocialServiceCase? @relation(fields: [socialServiceCaseId], references: [id], onDelete: SetNull)
  citizenFeedbackId String?
  citizenFeedback   CitizenFeedback? @relation(fields: [citizenFeedbackId], references: [id], onDelete: SetNull)
  createdAt  DateTime @default(now())

  @@index([gasRequestId])
  @@index([returneeRegistrationId])
  @@index([socialServiceCaseId])
  @@index([citizenFeedbackId])
}

/// Atomic yearly counter for request numbers: REQ-YYYY-NNNNN
model RequestSerial {
  year  Int      @id
  lastN Int
}

/// طلبات خدمات الغاز (نموذج بسيط مستقل عن طلبات الخدمات العامة)
model GasRequest {
  id               String   @id @default(cuid())
  gasRequestNumber String   @unique
  citizenId        String
  citizen          User     @relation(fields: [citizenId], references: [id], onDelete: Cascade)
  area             String
  assignedAgentId  String?
  assignedAgent    User?    @relation("GasRequestAgent", fields: [assignedAgentId], references: [id], onDelete: SetNull)
  notifications    Notification[]
  fullName         String
  phone            String
  nationalId       String
  isCompleted      Boolean  @default(false)
  completedAt      DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([createdAt])
  @@index([phone])
  @@index([nationalId])
  @@index([area])
  @@index([assignedAgentId])
  @@index([isCompleted])
}

/// عدّاد سنوي لطلبات الغاز: GAS-YYYY-NNNNN
model GasRequestSerial {
  year  Int @id
  lastN Int
}

enum ReturneeRegistrationStatus {
  PENDING
  UNDER_REVIEW
  APPROVED
  REJECTED
}

/// تسجيل العائدين — نموذج مستقل مع مرفق بيان العودة
model ReturneeRegistration {
  id                       String   @id @default(cuid())
  registrationNumber       String   @unique
  citizenId                String
  citizen                  User     @relation(fields: [citizenId], references: [id], onDelete: Cascade)
  fullName                 String
  birthDate                DateTime
  nationalId               String
  phone                    String
  email                    String
  returnStatementPath      String
  returnStatementOriginal  String
  returnStatementMime      String
  returnStatementSize      Int
  status                   ReturneeRegistrationStatus @default(PENDING)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
  notifications            Notification[]

  @@index([createdAt])
  @@index([nationalId])
  @@index([status])
}

enum SocialServiceCategory {
  DIVORCED
  WIDOWS
  ORPHANS
  DISABILITIES
  CHRONIC_DISEASES
  FAMILY_CENSUS
}

enum SocialServiceCaseStatus {
  PENDING
  UNDER_REVIEW
  APPROVED
  REJECTED
}

model SocialServiceCase {
  id                    String   @id @default(cuid())
  caseNumber            String   @unique
  category              SocialServiceCategory
  citizenId             String
  citizen               User     @relation(fields: [citizenId], references: [id], onDelete: Cascade)
  fullName              String?
  birthDate             DateTime?
  nationalId            String?
  phone                 String
  husbandFullName       String?
  husbandBirthDate      DateTime?
  husbandNationalId     String?
  wifeFullName          String?
  wifeBirthDate         DateTime?
  wifeNationalId        String?
  familyBookNumber      String?
  email                 String
  attachmentsJson       String   @default("[]")
  status                SocialServiceCaseStatus @default(PENDING)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  notifications         Notification[]

  @@index([createdAt])
  @@index([category])
  @@index([status])
  @@index([nationalId])
  @@index([husbandNationalId])
  @@index([wifeNationalId])
  @@index([familyBookNumber])
  @@unique([category, nationalId])
  @@unique([category, husbandNationalId])
  @@unique([category, wifeNationalId])
  @@unique([category, familyBookNumber])
}

model SocialServiceCaseSerial {
  year  Int @id
  lastN Int
}

model ReturneeRegistrationSerial {
  year  Int @id
  lastN Int
}
