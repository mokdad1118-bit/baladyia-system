# انسخ إلى .env وعدّل القيم — لا ترفع .env إلى Git

# —— Render / إنتاج (مهم) ——
# إن ظهرت صفحة NextAuth: «Server error / problem with the server configuration»
# فالسبب غالباً AUTH_SECRET فارغ. في Render: Environment → أضف AUTH_SECRET (قيمة عشوائية طويلة).
# أنشئ مثلاً من الطرفية: openssl rand -base64 32
# AUTH_URL يجب أن يطابق رابط الموقع العلني (https) بدون شرطة أخيرة، مثل:
# AUTH_URL=https://اسم-الخدمة.onrender.com
# (لا تستخدم NEXTAUTH_URL — Auth.js v5 يعتمد AUTH_URL و AUTH_SECRET)
#
# أمر التشغيل (package.json → npm run start): يشغّل prisma migrate deploy ثم next start
# حتى تُطبَّق الجداول على Render/VPS حتى لو نسيت أمر Release منفصل.
# للتحقق السريع بعد النشر: افتح GET /api/health (يرى ما إذا كان AUTH_SECRET مضبوطاً).
#
# —— وصول من سوريا أو شبكات مقيدة (بدون VPN) ——
# الكود لا يفرض منطقة جغرافية. إن لم يُفتح الموقع من داخل سوريا فغالباً الحجب أو التوجيه عند المزوّد، وليس خطأ التطبيق.
# إجراءات شائعة: نطاق خاص بدلاً من *.onrender.com؛ Cloudflare أمام النطاق؛ أو VPS في منطقة تصلها شبكتكم بلا وسيط.
# يجب أن يطابق AUTH_URL تماماً ما يكتبه المستخدم في المتصفح (نفس https والدومين).

# مطلوب في الإنتاج: مفتاح عشوائي قوي (مثلاً: openssl rand -base64 32)
# على Vercel يُقبل أيضاً NEXTAUTH_SECRET أو JWT_SECRET (نفس الغرض).
AUTH_SECRET=
# NEXTAUTH_SECRET=
# JWT_SECRET=

# عنوان الموقع العلني (مهم لجلسات NextAuth على HTTPS)
# مثال: https://portal.example.com
AUTH_URL=http://localhost:3000

# (اختياري) نفس منطق AUTH_URL بدون شرطة أخيرة — لروابط مطلقة في تصدير Excel للمرفقات إن لم يُستنتج العنوان من الطلب.
# NEXT_PUBLIC_APP_URL=https://portal.example.com

# OneSignal Web Push
# داخل لوحة OneSignal اضبط اسم الموقع/التطبيق على: بوابة محافظة درعا
# واضبط Default Icon URL على: https://YOUR_DOMAIN/brand/icon-256.png
# إن وجدت إعدادات Service Worker في لوحة OneSignal فاضبطها على:
# Path: /push/onesignal/OneSignalSDKWorker.js
# Scope: /push/onesignal/
NEXT_PUBLIC_ONESIGNAL_APP_ID=
ONESIGNAL_REST_API_KEY=

# تطوير من موبايل على نفس Wi‑Fi:
# 1) أضف عنوان IPv4 لجهاز الكمبيوتر (من ipconfig / أو الإعدادات): بدون منفذ، يمكن أكثر من عنوان مفصول بفاصلة
# LOCAL_LAN_HOSTS=192.168.1.11
# 2) عند الدخول من الهاتف استخدم نفس العنوان في الرابط؛ ولجلسات تسجيل الدخول عيّن AUTH_URL ليطابق ما تكتبه في المتصفح، مثلاً:
# AUTH_URL=http://192.168.1.11:3000

# —— فصل لوحة التحكم عن تطبيق المواطن (اختياري) ——
# فقط عند نشرين/نطاقين مختلفين فعلياً. على Render بنشر واحد: لا تضبط ADMIN_PORTAL_HOST ولا
# NEXT_PUBLIC_STAFF_PORTAL_URL على نفس الدومين — وإلا يُحوَّل /admin إلى /citizen/login.
# ADMIN_PORTAL_HOST=admin.localhost
# NEXT_PUBLIC_STAFF_PORTAL_URL=http://admin.localhost:3000
# NEXT_PUBLIC_CITIZEN_PORTAL_URL=http://localhost:3000
# للتطوير: أضف في hosts السطر 127.0.0.1 admin.localhost ثم شغّل نفس التطبيق على المنفذين أو نفس المنفذ مع Host مختلف.

# قاعدة البيانات — أحد الخيارين:
# (أ) تطوير محلي: اتركه فارغاً ليُستخدم prisma/dev.db تلقائياً
# (ب) Docker/VPS: file:///data/eportal.db (مع volume كما في docker-compose)
# (ج) Turso (LibSQL سحابي): libsql://....turso.io + TURSO_AUTH_TOKEN
DATABASE_URL=

# معرّف Turso (فقط عند استخدام رابط libsql:// أو https:// لـ Turso)
TURSO_AUTH_TOKEN=

# —— بريد OTP (تفعيل الحساب، نسيت كلمة المرور) — Nodemailer / SMTP ——
# مثال Gmail (منفذ 587، TLS):
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USER=you@gmail.com
# EMAIL_PASS=xxxx xxxx xxxx xxxx
# اختياري: EMAIL_SECURE=true فقط مع المنفذ 465
# EMAIL_SECURE=false

# —— Render.com / إنتاج ——
# عنوان الموقع العلني بدون شرطة أخيرة (يقلّل MissingCSRF عند signOut):
# AUTH_URL=https://اسم-الخدمة.onrender.com
# أو NEXTAUTH_URL بنفس القيمة
#
# PWA معطّل في بناء الإنتاج ما لم تضبط: ENABLE_PWA=1
#
# بريد OTP — على Render يُفضّل Resend (HTTPS) لأن SMTP أحياناً يتعطل (ETIMEDOUT):
# RESEND_API_KEY=re_...
# بدون نطاق موثّق في resend.com/domains، Resend يرفض (403) إرسال التفعيل لأي بريد سوى بريد مالك حساب Resend.
# الحل الإنتاجي: ثبّت النطاق في Resend ثم RESEND_FROM_EMAIL=noreply@نطاقك الموثّق
# RESEND_FROM_EMAIL=onboarding@resend.dev

# ملاحظة مهمة:
# في start نستخدم scripts/prepare-db.ts:
# - إذا DATABASE_URL محلي (file:) => ينفذ prisma migrate deploy
# - إذا DATABASE_URL libsql/https (Turso) => يطبق prisma/migrations مباشرة على LibSQL

# إنشاء/تثبيت حساب الأدمن تلقائياً عند التشغيل (npm start)
# يمكن تركها فارغة لاستخدام القيم الافتراضية:
# BOOTSTRAP_ADMIN_EMAIL=admin@daraa.local
# BOOTSTRAP_ADMIN_PASSWORD=Admin123
# BOOTSTRAP_ADMIN_NAME=مشرف محافظة درعا
# لإجبار تحديث كلمة المرور في كل تشغيل (اختياري): 1
# BOOTSTRAP_ADMIN_RESET_PASSWORD=0
